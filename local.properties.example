# Cognilink Backend - Environment Configuration Example
# Copy this file to 'local.properties' and fill in your values

# Gemini AI API Key
# Obtain yours at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Redis Configuration (Used for Feynman Chat sessions)
# For local study, keep localhost and 6379.
# Make sure Redis is running (e.g., via Docker: docker run -p 6379:6379 redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: Redis Password (leave empty if not set)
# REDIS_PASSWORD=
